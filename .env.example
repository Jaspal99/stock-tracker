# Privy mobile app credentials
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Optional Cloudflare Worker URL. The app falls back to public providers directly.
EXPO_PUBLIC_API_BASE_URL=

# Used directly only when no Cloudflare Worker URL is configured.
EXPO_PUBLIC_BIRDEYE_API_KEY=
EXPO_PUBLIC_JUPITER_API_KEY=

# Use an Alchemy devnet URL during testing, then a mainnet URL.
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_SOLANA_CLUSTER=devnet

# Optional Supabase persistence
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
